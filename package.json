{
  "name": "louvorja",
  "version": "1.5.1",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "version:major": "npm version major",
    "version:minor": "npm version minor",
    "version:patch": "npm version patch",
    "version:max": "npm version major",
    "version:min": "npm version minor",
    "version:bug": "npm version patch",
    "serve": "vite preview",
    "build": "vite build",
    "lint": "eslint src --ext .vue,.js --fix",
    "dev": "vite",
    "host": "vite --host",
    "files": "node node/server.js",
    "git:tag": "git tag -a -f v%npm_package_version% -m \"Versão %npm_package_version%\" && git push origin -f v%npm_package_version% && git push -u origin main",
    "git:publish": "git pull origin main && git checkout main && git merge develop && git push -u origin main && git checkout develop",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build --base=./ && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "archiver": "^7.0.1",
    "basic-ftp": "^5.0.5",
    "better-sqlite3": "^12.11.1",
    "core-js": "^3.46.0",
    "dotenv": "^16.6.1",
    "electron-updater": "^6.8.9",
    "fs-extra": "^11.3.2",
    "roboto-fontface": "*",
    "systeminformation": "^5.31.11",
    "vue": "^3.5.22",
    "vue-country-flag-next": "^2.3.2",
    "vue-fullscreen": "^3.1.3",
    "vue-i18n": "^10.0.8",
    "vue-json-pretty": "^2.6.0",
    "vue-router": "^4.6.3",
    "vue3-shortkey": "^4.0.0",
    "vuedraggable": "^4.1.0",
    "vuetify": "^3.7.4",
    "vuex": "^4.1.0",
    "webfontloader": "^1.6.28"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/eslint-parser": "^7.25.9",
    "@babel/preset-env": "^7.28.5",
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^10.0.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.31.0",
    "sass": "^1.83.0",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^0.21.2",
    "vite-plugin-vuetify": "^2.0.4",
    "wait-on": "^9.0.10"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "build": {
    "appId": "com.louvorja.app",
    "productName": "Louvor JA",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      "resources/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "elvieira",
      "repo": "LouvorJA"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/ico/favicon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "public/ico/favicon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/ico/favicon.png"
    }
  }
}
